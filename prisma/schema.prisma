generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ceo
  admin
  developer
  designer
  client
}

enum ProjectType {
  external
  internal
}

enum ProjectStatus {
  on_track
  at_risk
  delayed
  completed
}

enum GoalStatus {
  pending
  in_progress
  completed
}

enum SprintStatus {
  planned
  active
  completed
}

enum MilestoneStatus {
  pending
  completed
}

enum TaskCategory {
  engineering
  design
  marketing
  other
}

enum TaskStatus {
  backlog
  ready
  in_progress
  blocked
  in_review
  done
}

enum Mood {
  great
  good
  okay
  struggling
}

enum TrainingStatus {
  active
  completed
  paused
}

enum ResourceType {
  video
  article
  course
  practice
}

enum TopicStatus {
  pending
  in_progress
  completed
}

enum ReportType {
  daily_dev
  daily_project
  sprint
  demo
}

enum DocumentType {
  specification
  meeting_notes
  wiki
  other
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         Role
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")

  teamMembers        TeamMember[]
  assignedTasks      Task[]
  reviewedTasks      Task[]             @relation("TaskReviewer")
  taskComments       TaskComment[]
  developerProfile   DeveloperProfile?
  dailyStatuses      DailyStatus[]
  trainingPaths      TrainingPath[]
  assignedPaths      TrainingPath[]     @relation("AssignedByUser")
  reports            Report[]
  googleIntegration  GoogleIntegration?

  oneOnOneNotesAsSubject      OneOnOneNote[]      @relation("NoteSubject")
  oneOnOneNotesAsAuthor       OneOnOneNote[]      @relation("NoteAuthor")
  performanceReviewsAsSubject PerformanceReview[] @relation("ReviewSubject")
  performanceReviewsAsAuthor  PerformanceReview[] @relation("ReviewAuthor")

  avatarConfig         AvatarConfig?
  createdBattlePaths   BattleLearningPath[] @relation("PathCreator")
  assignedBattlePaths  UserBattlePath[]
  battleProgress       UserBattleProgress[]

  createdDocuments  ProjectDocument[] @relation("DocumentCreator")
  editedDocuments   ProjectDocument[] @relation("DocumentEditor")

  @@map("users")
}

model Team {
  id        String   @id @default(uuid())
  name      String
  projectId String   @map("project_id")
  createdAt DateTime @default(now()) @map("created_at")

  project     Project      @relation(fields: [projectId], references: [id])
  teamMembers TeamMember[]

  @@map("teams")
}

model TeamMember {
  id     String @id @default(uuid())
  teamId String @map("team_id")
  userId String @map("user_id")

  team Team @relation(fields: [teamId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@map("team_members")
}

model Project {
  id          String        @id @default(uuid())
  name        String
  description String?
  type        ProjectType
  status      ProjectStatus @default(on_track)
  budget      Decimal?
  deadline    DateTime?
  clientName  String?       @map("client_name")
  createdAt   DateTime      @default(now()) @map("created_at")

  teams       Team[]
  goals       Goal[]
  sprints     Sprint[]
  milestones  RoadmapMilestone[]
  tasks       Task[]
  reports     Report[]
  driveFolder ProjectDriveFolder?
  documents   ProjectDocument[]

  @@map("projects")
}

model Goal {
  id          String     @id @default(uuid())
  projectId   String     @map("project_id")
  title       String
  description String?
  deadline    DateTime?
  status      GoalStatus @default(pending)

  project Project @relation(fields: [projectId], references: [id])
  tasks   Task[]

  @@map("goals")
}

model Sprint {
  id        String       @id @default(uuid())
  projectId String       @map("project_id")
  name      String
  objective String?
  startDate DateTime     @map("start_date")
  endDate   DateTime     @map("end_date")
  status    SprintStatus @default(planned)

  project    Project            @relation(fields: [projectId], references: [id])
  milestones RoadmapMilestone[]
  tasks      Task[]

  @@map("sprints")
}

model RoadmapMilestone {
  id        String          @id @default(uuid())
  projectId String          @map("project_id")
  sprintId  String?         @map("sprint_id")
  title     String
  dueDate   DateTime        @map("due_date")
  status    MilestoneStatus @default(pending)

  project Project @relation(fields: [projectId], references: [id])
  sprint  Sprint? @relation(fields: [sprintId], references: [id])

  @@map("roadmap_milestones")
}

model Task {
  id           String       @id @default(uuid())
  projectId    String       @map("project_id")
  sprintId     String?      @map("sprint_id")
  goalId       String?      @map("goal_id")
  assignedTo   String?      @map("assigned_to")
  title        String
  description  String?
  category     TaskCategory @default(engineering)
  status       TaskStatus   @default(backlog)
  storyPoints  Int?         @map("story_points")
  estimatedHrs Decimal?     @map("estimated_hrs")
  prLink       String?      @map("pr_link")
  reviewedBy   String?      @map("reviewed_by")
  reviewedAt   DateTime?    @map("reviewed_at")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  project  Project       @relation(fields: [projectId], references: [id])
  sprint   Sprint?       @relation(fields: [sprintId], references: [id])
  goal     Goal?         @relation(fields: [goalId], references: [id])
  assignee User?         @relation(fields: [assignedTo], references: [id])
  reviewer User?         @relation("TaskReviewer", fields: [reviewedBy], references: [id])
  comments TaskComment[]

  @@index([projectId])
  @@index([assignedTo])
  @@index([status])
  @@index([sprintId])
  @@index([projectId, status])
  @@index([assignedTo, status])
  @@index([updatedAt])
  @@map("tasks")
}

model TaskComment {
  id        String   @id @default(uuid())
  taskId    String   @map("task_id")
  authorId  String   @map("author_id")
  body      String
  createdAt DateTime @default(now()) @map("created_at")

  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id])

  @@map("task_comments")
}

model DeveloperProfile {
  id                 String @id @default(uuid())
  userId             String @unique @map("user_id")
  skills             String[]
  weeklyCapacityHrs  Int?   @map("weekly_capacity_hrs")
  bio                String?

  user User @relation(fields: [userId], references: [id])

  @@map("developer_profiles")
}

model DailyStatus {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  date            DateTime  @db.Date
  mood            Mood
  availableHrs    Decimal?  @map("available_hrs")
  appointments    String?
  blockers        String?
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")

  eodMood         Mood?     @map("eod_mood")
  eodCompleted    String?   @map("eod_completed")
  eodBlockers     String?   @map("eod_blockers")
  eodNotes        String?   @map("eod_notes")
  eodSubmittedAt  DateTime? @map("eod_submitted_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@map("daily_status")
}

model TrainingPath {
  id            String         @id @default(uuid())
  userId        String         @map("user_id")
  skill         String
  resources     Json?
  progressPct   Int            @default(0) @map("progress_pct")
  status        TrainingStatus @default(active)
  title         String         @default("")
  careerPath    String?        @map("career_path")
  description   String?
  assignedBy    String?        @map("assigned_by")
  generatedByAI Boolean        @default(false) @map("generated_by_ai")
  dueDate       DateTime?      @map("due_date")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  user           User            @relation(fields: [userId], references: [id])
  assignedByUser User?           @relation("AssignedByUser", fields: [assignedBy], references: [id])
  topics         LearningTopic[]

  @@index([userId])
  @@map("training_paths")
}

model LearningTopic {
  id             String       @id @default(uuid())
  trainingPathId String       @map("training_path_id")
  title          String
  description    String?
  resourceUrl    String?      @map("resource_url")
  resourceType   ResourceType @default(article) @map("resource_type")
  orderIndex     Int          @map("order_index")
  dueDate        DateTime?    @map("due_date")
  status         TopicStatus  @default(pending)
  completedAt    DateTime?    @map("completed_at")
  createdAt      DateTime     @default(now()) @map("created_at")

  trainingPath TrainingPath @relation(fields: [trainingPathId], references: [id], onDelete: Cascade)

  @@unique([trainingPathId, orderIndex])
  @@map("learning_topics")
}

model Report {
  id        String     @id @default(uuid())
  type      ReportType
  projectId String?    @map("project_id")
  userId    String?    @map("user_id")
  content   Json
  createdAt DateTime   @default(now()) @map("created_at")
  driveUrl  String?    @map("drive_url")

  project Project? @relation(fields: [projectId], references: [id])
  user    User?    @relation(fields: [userId], references: [id])

  @@map("reports")
}

model GoogleIntegration {
  id           String    @id @default(uuid())
  userId       String    @unique @map("user_id")
  accessToken  String    @map("access_token")
  refreshToken String?   @map("refresh_token")
  tokenExpiry  DateTime  @map("token_expiry")
  scope        String
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("google_integrations")
}

model ProjectDriveFolder {
  id        String   @id @default(uuid())
  projectId String   @unique @map("project_id")
  folderId  String   @map("folder_id")
  createdAt DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_drive_folders")
}

model OneOnOneNote {
  id           String   @id @default(uuid())
  subjectId    String   @map("subject_id")
  authorId     String   @map("author_id")
  sessionDate  DateTime @map("session_date") @db.Date
  notes        String
  strengths    String?
  improvements String?
  agreements   String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  subject User @relation("NoteSubject", fields: [subjectId], references: [id])
  author  User @relation("NoteAuthor",  fields: [authorId],  references: [id])

  @@map("one_on_one_notes")
}

// ── Learning Battles ──────────────────────────────────────────────────────────

model AvatarConfig {
  id             String   @id @default(uuid())
  userId         String   @unique @map("user_id")
  body           String   @default("round")
  head           String   @default("round")
  primaryColor   String   @default("#6366f1") @map("primary_color")
  secondaryColor String   @default("#a5b4fc") @map("secondary_color")
  accentColor    String   @default("#fbbf24") @map("accent_color")
  accessory      String   @default("none")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("avatar_configs")
}

model EnemyImage {
  id         String   @id @default(uuid())
  filename   String   @unique
  uploadedAt DateTime @default(now()) @map("uploaded_at")

  battleProgress UserBattleProgress[]

  @@map("enemy_images")
}

model BattleTopic {
  id          String   @id @default(uuid())
  title       String
  description String?
  icon        String   @default("📚")
  orderIndex  Int      @map("order_index")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  battles      BattleFight[]
  pathTopics   BattlePathTopic[]
  userProgress UserBattleProgress[]

  @@map("battle_topics")
}

model BattleFight {
  id            String   @id @default(uuid())
  topicId       String   @map("topic_id")
  title         String
  order         Int
  questionsJson Json     @map("questions_json")
  createdAt     DateTime @default(now()) @map("created_at")

  topic    BattleTopic          @relation(fields: [topicId], references: [id], onDelete: Cascade)
  progress UserBattleProgress[]

  @@unique([topicId, order])
  @@map("battle_fights")
}

model BattleLearningPath {
  id        String   @id @default(uuid())
  title     String
  createdBy String   @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  creator   User              @relation("PathCreator", fields: [createdBy], references: [id])
  topics    BattlePathTopic[]
  userPaths UserBattlePath[]

  @@map("battle_learning_paths")
}

model BattlePathTopic {
  id         String @id @default(uuid())
  pathId     String @map("path_id")
  topicId    String @map("topic_id")
  orderIndex Int    @map("order_index")

  path  BattleLearningPath @relation(fields: [pathId], references: [id], onDelete: Cascade)
  topic BattleTopic        @relation(fields: [topicId], references: [id])

  @@unique([pathId, topicId])
  @@map("battle_path_topics")
}

model UserBattlePath {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  pathId     String   @map("path_id")
  assignedAt DateTime @default(now()) @map("assigned_at")

  user User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  path BattleLearningPath @relation(fields: [pathId], references: [id], onDelete: Cascade)

  @@unique([userId, pathId])
  @@map("user_battle_paths")
}

model UserBattleProgress {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  topicId       String    @map("topic_id")
  battleId      String    @map("battle_id")
  enemyImageId  String?   @map("enemy_image_id")
  completed     Boolean   @default(false)
  score         Int       @default(0)
  attempts      Int       @default(0)
  lastAttemptAt DateTime? @map("last_attempt_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic      BattleTopic @relation(fields: [topicId], references: [id])
  battle     BattleFight @relation(fields: [battleId], references: [id])
  enemyImage EnemyImage? @relation(fields: [enemyImageId], references: [id])

  @@unique([userId, battleId])
  @@index([userId, topicId])
  @@map("user_battle_progress")
}

model ProjectDocument {
  id        String       @id @default(uuid())
  projectId String       @map("project_id")
  title     String
  content   Json?
  type      DocumentType @default(wiki)
  createdBy String       @map("created_by")
  updatedBy String       @map("updated_by")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator    User    @relation("DocumentCreator", fields: [createdBy], references: [id])
  lastEditor User    @relation("DocumentEditor", fields: [updatedBy], references: [id])

  @@map("project_documents")
}

model PerformanceReview {
  id               String   @id @default(uuid())
  subjectId        String   @map("subject_id")
  authorId         String   @map("author_id")
  periodLabel      String   @map("period_label")
  periodStart      DateTime @map("period_start") @db.Date
  periodEnd        DateTime @map("period_end")   @db.Date
  ratingTechnical  Int?     @map("rating_technical")
  ratingComms      Int?     @map("rating_comms")
  ratingAutonomy   Int?     @map("rating_autonomy")
  ratingTeamwork   Int?     @map("rating_teamwork")
  overallRating    Int?     @map("overall_rating")
  summary          String?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  subject User @relation("ReviewSubject", fields: [subjectId], references: [id])
  author  User @relation("ReviewAuthor",  fields: [authorId],  references: [id])

  @@map("performance_reviews")
}
